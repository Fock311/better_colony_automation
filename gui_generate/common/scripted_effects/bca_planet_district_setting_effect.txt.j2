{% import 'component/planet_flag_ps.j2' as pf with context -%}
{% import 'component/planet_variable.j2' as v -%}
{% import 'component/planet_variable.j2' as v -%}

try_set_secondary_districts_plan_zero_to_one = {
    {% for i in range(3,6) %}
    {% set zone_slot = "z"~(i) %}
    if = {
        limit = {
             check_variable = {
                 which = {{v.var_district_num_plan(zone_slot)}}
                 value = 0
             }
            check_variable_arithmetic = {
                which = value:bca_num_free_secondary_districts_plan
                value > 0
            }
        }
        add_variable = {
            which = {{v.var_district_num_plan(zone_slot)}}
            value = 1
        }
    }
    {% endfor %}
}

try_set_secondary_districts_plan_one_to_zero = {
    bca_set_secondary_district_type_flag = yes
    {% for i in range(3,6) %}
    {% set zone_slot = "z"~(i) %}
    {% for district in secondary_districts %}
    if = {
        limit = {
             has_planet_flag = {{ pf.flag_zone_district(zone_slot, district) }}
             NOT = { has_district = {{district}} }
             check_variable = {
                 which = {{v.var_district_num_plan(zone_slot)}}
                 value = 1
             }
        }
        set_variable = {
            which = {{v.var_district_num_plan(zone_slot)}}
            value = 0
        }
    }
    {% endfor %}
    {% endfor %}
    bca_clean_flags_zone_selector_secondary_district = yes
}

bca_set_district_plan_by_ratio = {
    hidden_effect = {
        set_variable = {
            which = new_num_main_districts_plan_diff
            value = value:bca_num_main_districts_from_ratio|RATIO|$RATIO$|
        }
        subtract_variable = {
             which = new_num_main_districts_plan_diff
             value = value:bca_num_primary_districts_plan
        }
        bca_set_district_plan_by_diff = yes
    }
}

bca_set_district_plan_inc_1 = {
    set_variable = {
        which = new_num_main_districts_plan_diff
        value = 1
    }
    bca_set_district_plan_by_diff = yes
}

bca_set_district_plan_dec_1 = {
    set_variable = {
        which = new_num_main_districts_plan_diff
        value = -1
    }
    bca_set_district_plan_by_diff = yes
}

bca_set_district_plan_by_diff = {
    {# planed district reduce #}
    while = {
        limit = {
            check_variable = {
                which = new_num_main_districts_plan_diff
                value > 0
            }
            NOT = { has_planet_flag = bca_no_more_planed_secondary_district }
        }
        set_planet_flag = bca_no_more_planed_secondary_district
        {% for i in range(3,6) %}
        {% set zone_slot = "z"~(i) %}
        if = {
            limit = {
                check_variable = {
                    which = {{v.var_district_num_plan(zone_slot)}}
                    value > value:num_district_{{ zone_slot_district_slot_mapping[zone_slot] }}
                }
                 check_variable = {
                     which = new_num_main_districts_plan_diff
                     value > 0
                 }
            }
            subtract_variable = {
                which = {{v.var_district_num_plan(zone_slot)}}
                value = 1
            }
            subtract_variable = {
                which = new_num_main_districts_plan_diff
                value = 1
            }
            remove_planet_flag = bca_no_more_planed_secondary_district
        }
        {% endfor %}
    }
    {# built secondary district reduce #}
    if = {
        limit = {
            has_planet_flag = bca_no_more_planed_secondary_district
            NOT = { has_planet_flag = bca_pf_disable_planet_auto_destruction_district }
        }
        remove_planet_flag = bca_no_more_planed_secondary_district
        while = {
            limit = {
                check_variable = {
                    which = new_num_main_districts_plan_diff
                    value > 0
                }
                NOT = { has_planet_flag = bca_no_more_planed_secondary_district }
            }
            set_planet_flag = bca_no_more_planed_secondary_district
            {% for i in range(3,6) %}
            {% set zone_slot = "z"~(i) %}
            if = {
                limit = {
                    check_variable = {
                        which = {{v.var_district_num_plan(zone_slot)}}
                        value > 0
                    }
                     check_variable = {
                         which = new_num_main_districts_plan_diff
                         value > 0
                     }
                }
                subtract_variable = {
                    which = {{v.var_district_num_plan(zone_slot)}}
                    value = 1
                }
                subtract_variable = {
                    which = new_num_main_districts_plan_diff
                    value = 1
                }
                remove_planet_flag = bca_no_more_planed_secondary_district
            }
            {% endfor %}
        }
    }
    remove_planet_flag = bca_no_more_planed_secondary_district

    {# secondary district increment #}
    while = {
        limit = {
            check_variable = {
                which = new_num_main_districts_plan_diff
                value < 0
            }
            NOT = { has_planet_flag = bca_no_more_free_secondary_district }
        }
        set_planet_flag = bca_no_more_free_secondary_district
        {% for i in range(3,6) %}
        {% set zone_slot = "z"~(i) %}
        {% set district_slot = zone_slot_district_slot_mapping[zone_slot] %}
        if = {
            limit = {
                check_variable = {
                    which = {{v.var_district_num_plan(zone_slot)}}
                    value < value:bca_potential_district_max_add_{{ district_slot }}
                }
                check_variable = {
                    which = new_num_main_districts_plan_diff
                    value < 0
                }
                OR = {
                    bca_has_advance_secondary_districts = yes
                    AND = {
                        {% set generator_zone_slot = 'z3' %}
                        {% set mining_zone_slot = 'z4' %}
                        {% set farming_zone_slot = 'z5' %}
                        {% set generator_district_slot = zone_slot_district_slot_mapping[generator_zone_slot] %}
                        {% set mining_district_slot = zone_slot_district_slot_mapping[mining_zone_slot] %}
                        {% set farming_district_slot = zone_slot_district_slot_mapping[farming_zone_slot] %}
                        {% if zone_slot == farming_zone_slot or zone_slot == mining_zone_slot %}
                        OR = {
                             has_generator_designation = no
                             check_variable = {
                                which = {{v.var_district_num_plan(generator_zone_slot)}}
                                value >= value:bca_potential_district_max_add_{{ generator_district_slot }}
                            }
                        }
                        {% endif %}
                        {% if zone_slot == generator_zone_slot or zone_slot == farming_zone_slot %}
                        OR = {
                             has_mining_designation = no
                             check_variable = {
                                which = {{v.var_district_num_plan(mining_zone_slot)}}
                                value >= value:bca_potential_district_max_add_{{ mining_district_slot }}
                            }
                        }
                        {% endif %}
                        {% if zone_slot == generator_zone_slot or zone_slot == mining_zone_slot %}
                        OR = {
                             has_farming_designation = no
                             check_variable = {
                                which = {{v.var_district_num_plan(farming_zone_slot)}}
                                value >= value:bca_potential_district_max_add_{{ farming_district_slot }}
                            }
                        }
                        {% endif %}
                    }
                }
            }
            add_variable = {
                which = {{v.var_district_num_plan(zone_slot)}}
                value = 1
            }
            add_variable = {
                which = new_num_main_districts_plan_diff
                value = 1
            }
            remove_planet_flag = bca_no_more_free_secondary_district
        }
        {% endfor %}
    }
    remove_planet_flag = bca_no_more_free_secondary_district
    clear_variable = new_num_main_districts_plan_diff


}
