planet_event = {
	id = bca_debug_event.2

	is_triggered_only = yes
	title = "Test Event for Scripted Triggers"
	desc = bca_debug_event.1.desc

    option = {
        name = 'exit'
    }

	option = {
		name = "add pop"
		create_pop_group = { size = 1000  species = owner_main_species }
		planet_event = {
			id = bca_debug_event.2
		}
	}

	option = {
	    name = "test_effect"
	    test_effect = yes
	}

	option = {
	    name = "test_call"
        bca_resource_planet_controller_district_only = yes
	}

    option = {
        name = "test minerals zone building"
        allow = {
            check_variable_arithmetic = {
                which = value:num_secondary_zones_of_type_minerals
                value < value:num_secondary_zone_plan_of_type_minerals
            }
        }
        if = {
            limit = {
                requires_more_job = yes
            }
            set_planet_flag = debug_2_zone_path_minerals_z4
            # secondary zone
            if = {
                limit = {
                    has_planet_flag = bca_pf_ps_selected_zone_type_z4_minerals
                }
                set_planet_flag = debug_3_zone_path_minerals_z4_minerals
                # debug check_variable_arithmetic condition
                if = {
                    limit = {
                        check_variable_arithmetic = {
                            which = value:num_secondary_zones_of_type_minerals
                            value < value:num_secondary_zone_plan_of_type_minerals
                        }
                    }
                    set_planet_flag = debug_check_variable_arithmetic_minerals_z4_minerals
                }
                if = {
                    limit = {
                        check_variable_arithmetic = {
                            which = value:num_secondary_zones_of_type_minerals
                            value = 0
                        }
                    }
                    set_planet_flag = debug_check_variable_arithmetic_num_secondary_zones_of_type_minerals_eq_0
                }
                if = {
                    limit = {
                        check_variable_arithmetic = {
                            which = value:num_secondary_zone_plan_of_type_minerals
                            value = 0
                        }
                    }
                    set_planet_flag = debug_check_variable_arithmetic_num_secondary_zone_plan_of_type_minerals_eq_0
                }
            }

            else_if = {
                limit = {
                    has_planet_flag = bca_pf_ps_selected_zone_type_z4_wilderness_minerals
                }
                set_planet_flag = debug_3_zone_path_minerals_z4_wilderness_minerals
                # debug check_variable_arithmetic condition
                if = {
                    limit = {
                        check_variable_arithmetic = {
                            which = value:num_secondary_zones_of_type_wilderness_minerals
                            value < value:num_secondary_zone_plan_of_type_wilderness_minerals
                        }
                    }
                    set_planet_flag = debug_check_variable_arithmetic_minerals_z4_wilderness_minerals
                }
            }

            if = {
                limit = {
                    has_planet_flag = bca_pf_ps_selected_zone_type_z4_minerals
                    check_variable_arithmetic = {
                        which = value:num_secondary_zones_of_type_minerals
                        value < value:num_secondary_zone_plan_of_type_minerals
                    }
                    OR = {
                        bca_can_build_zone_minerals = yes
                        bca_can_build_zone_minerals_nexus = yes
                        bca_can_build_zone_minerals_hive = yes
                    }
                }
                set_planet_flag = bca_pf_plan_build_secondary_zone_type_minerals
                set_planet_flag = bca_plan_build_new_zone
                set_planet_flag = bca_pf_advance_controller_order
                set_planet_flag = debug_zone_path_minerals_z4_minerals
            }
            else_if = {
                limit = {
                    has_planet_flag = bca_pf_ps_selected_zone_type_z4_wilderness_minerals
                    check_variable_arithmetic = {
                        which = value:num_secondary_zones_of_type_wilderness_minerals
                        value < value:num_secondary_zone_plan_of_type_wilderness_minerals
                    }
                    OR = {
                        bca_can_build_zone_minerals_wilderness = yes
                    }
                }
                set_planet_flag = bca_pf_plan_build_secondary_zone_type_wilderness_minerals
                set_planet_flag = bca_plan_build_new_zone
                set_planet_flag = bca_pf_advance_controller_order
                set_planet_flag = debug_zone_path_minerals_z4_wilderness_minerals
            }
        }
        # secondary district
        if = {
            limit = {
                bca_auto_district_manage_enabled = yes
            }
            set_variable = {
                which = bca_ps_plan_district_count_z4
                value = value:bca_potential_district_max_build_d2
            }
            if = {
                limit = {
                    free_district_slots > 0
                    requires_more_job = yes
                }
                if = {
                    limit = {
                        NOT = { has_planet_flag = bca_pf_advance_controller_order }
                        check_variable_arithmetic = {
                            which = value:num_free_district_d2
                            value > 0
                        }
                    }
                    set_planet_flag = bca_pf_plan_build_district_d2
                    set_planet_flag = bca_pf_advance_controller_order
                    set_planet_flag = debug_district_path_minerals_d2
                }
                else = {
                    set_planet_flag = bca_pf_plan_build_district_d0
                }
            }
        }
    }

	immediate = {

	}

