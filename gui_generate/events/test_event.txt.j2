	{% for flag in test_flags %}
    option = {
        name = "{{ flag }}"
        allow = {
            has_planet_flag = {{ flag }}
        }
        planet_event = {
			id = bca_debug_event.2
		}
    }
    {% endfor %}

	{% for trigger in test_trigger %}
    option = {
        name = "{{ trigger }}"
        allow = {
            {{ trigger }} = yes
        }
        planet_event = {
			id = bca_debug_event.2
		}
    }
    {% endfor %}
	option = {
		name = "var_test"
	    {% for val in display_values %}
		set_variable = {
			which = {{val}}
			value = value:{{val}}
		}
		{% endfor %}
		hidden_effect = {
            {% for val in display_values %}
